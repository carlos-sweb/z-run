.{
    .name = .zrun,
    .version = "0.1.0",
    .minimum_zig_version = "0.16.0",
    .fingerprint = 0x8af1e23654497736,
    .description = "Minimal script runtime (CLI + synchronous fs bindings) for the z-* ECMAScript engine",
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src/",
        "README.md",
    },
    .dependencies = .{
        .zinterpreter = .{ .path = "../z-interpreter" },
        .zvalue = .{ .path = "../z-value" },
    },
}
